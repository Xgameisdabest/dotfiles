	case "$select" in
	"" | "$divider" | "$quit")
		echo "No option chosen."
		;;
	"$goback")
		show_menu
		;;
	*)
		dev_list_addr=$(bluetoothctl devices | grep "$select")
		if [[ $dev_list ]]; then
			device_list_trusted_entered=true
			device_menu "$dev_list_addr"
		fi
		;;
	esac
}

device_list_paired() {
	dev_list=$(bluetoothctl devices Paired | grep Device | cut -d ' ' -f 3- | sed 's/^/Ôäď /')

	device_list_menu_height=175
	numbers_of_devices=$(echo "$dev_list" | wc -l)
	height_per_device_entry=$((device_list_menu_height + (numbers_of_devices * 38)))
	if [[ $height_per_device_entry -gt 710 ]]; then
		height_per_device_entry=710
	fi

	options="$dev_list\n$goback\n$quit"
	select=$(echo -e "$options" | $rofi_command " Select Device ůįĺį  " -theme-str "listview {columns: 1; layout: vertical;}" -theme-str "window {width: 500px; location: $location; x-offset: $device_list_paired_menu_x_offset; y-offset: $device_list_paired_menu_y_offset; height: ${height_per_device_entry}px;}" | sed 's/Ôäď//g')
	case "$select" in
	"" | "$divider" | "$quit")
		echo "No option chosen."
		;;
	"$goback")
		show_menu
		;;
	*)
		dev_list_addr=$(bluetoothctl devices | grep "$select")
		if [[ $dev_list ]]; then
			device_list_paired_entered=true
			device_menu "$dev_list_addr"
		fi
		;;
	esac
}

device_menu() {
	device=$1

	device_name=$(echo "$device" | cut -d ' ' -f 3-)
	mac=$(echo "$device" | cut -d ' ' -f 2)

	if device_connected "$mac"; then
		connected="ůįāį  Connected: Yes"
	else
		connected="ůįāį  Connected: No"
	fi
	paired=$(device_paired "$mac")
	trusted=$(device_trusted "$mac")
	options="$connected\n$paired\n$trusted\n$goback\n$quit"

	chosen="$(echo -e "$options" | $rofi_command_non_search " $device_name ůįĺį  " -theme-str "window {height: 390; width: 350px; location: $location; x-offset: $device_menu_x_offset; y-offset: $device_menu_y_offset;}")"

	case "$chosen" in
	"" | "$divider")
		echo "No option chosen."
		;;
	"$connected")
		toggle_connection "$mac"
		;;
	"$paired")
		toggle_paired "$mac"
		;;
	"$trusted")
		toggle_trust "$mac"
		;;
	"$goback")
		if [[ $device_list_entered == true ]]; then
			device_list_entered=false
			device_list
		elif [[ $device_list_paired_entered == true ]]; then
			device_list_paired_entered=false
			device_list_paired
		elif [[ $device_list_trusted_entered == true ]]; then
			device_list_trusted_entered=false
			device_list_trusted
		fi
		;;
	esac
}

show_menu() {
	if power_on; then
		power="ÔÄĎ  Power: On"

		device_count=$(bluetoothctl devices | grep '^Device' | wc -l)
		trusted_device_count=$(bluetoothctl devices Trusted | grep '^Device' | wc -l)
		paired_device_count=$(bluetoothctl devices Paired | grep '^Device' | wc -l)

		devices="ÔĀŅ  Device List ($device_count) ÔĀ° "
		devices_trusted="ÔĀŅ  Trusted Device ($trusted_device_count) ÔĀ°"
		devices_paired="ÔĀŅ  Paired Device ($paired_device_count) ÔĀ°"

		bluetooth_manager="ůįĖĮ  Bluetooth Manager"

		scan=$(scan_on)
		pairable=$(pairable_on)
		discoverable=$(discoverable_on)

		options="$devices\n$power\n$scan\n$pairable\n$discoverable\n$devices_trusted\n$devices_paired\n$bluetooth_manager\n$quit"

		connected_devices=$(bluetoothctl devices Connected | grep Device | cut -d ' ' -f 3- | sed 's/^/Ôäď /')

		# long but worked
		if [[ $connected_devices != "" ]]; then
			amount_currently_connected=$(echo -e "Device Connected:\n$connected_devices")

			numbers_of_line=$(echo -e "$connected_devices" | wc -l)
			main_menu_height=505
			main_menu_height=$((main_menu_height + (numbers_of_line * 25)))
			main_menu_height="${main_menu_height}px"
			chosen="$(echo -e "$options" | rofi -x11 -dmenu -mesg "$amount_currently_connected" -i -theme-str "window {height: $main_menu_height; width: $main_menu_width; location: $location; x-offset: $main_menu_x_offset; y-offset: $main_menu_y_offset;}" -theme-str "listview {columns: 1; layout: vertical;}" -theme $path_to_theme -p " Bluetooth ÔäĒ ")"
		else
			amount_currently_connected=""
			main_menu_height="${main_menu_height}px"
			chosen="$(echo -e "$options" | rofi -x11 -dmenu -i -theme-str "window {height: $main_menu_height; width: $main_menu_width; location: $location; x-offset: $main_menu_x_offset; y-offset: $main_menu_y_offset;}" -theme-str "listview {columns: 1; layout: vertical;}" -theme $path_to_theme -p " Bluetooth ÔäĒ ")"
		fi

		case "$chosen" in
		"" | "$divider")
			echo "No option chosen."
			;;
		"$devices")
			device_list
			;;
		"$devices_trusted")
			device_list_trusted
			;;
		"$devices_paired")
			device_list_paired
			;;
		"$power")
			toggle_power
			;;
		"$scan")
			toggle_scan
			;;
		"$discoverable")
			toggle_discoverable
			;;
		"$bluetooth_manager")
			blueman-manager
			;;
		"$pairable")
			toggle_pairable
			;;
		esac

	else
		power="ÔÄĎ  Power: Off"
		options_off="$power\n$quit"
		chosen="$(echo -e "$options_off" | rofi -x11 -dmenu -i -theme-str "window {height: $main_menu_height_off; width: $main_menu_width; location: $location; x-offset: $main_menu_x_offset; y-offset: $main_menu_y_offset;}" -theme $path_to_theme -p " Bluetooth ÔäĒ ")"

		case "$chosen" in
		"" | "$divider")
			echo "No option chosen."
			;;
		"$power")
			toggle_power
			;;
		esac

	fi
}

rofi_command="rofi -x11 -dmenu -i -theme $path_to_theme_search -p "
rofi_command_non_search="rofi -x11 -dmenu -i -theme $path_to_theme -p "

case "$1" in
--status)
	print_status
	;;
*)
	show_menu
	;;
esac
